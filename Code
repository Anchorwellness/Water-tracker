<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Hydrate</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a1628;
    --surface: #111f38;
    --water-light: #38bdf8;
    --water-mid: #0ea5e9;
    --water-deep: #0369a1;
    --foam: #bae6fd;
    --gold: #fbbf24;
    --text: #e0f2fe;
    --muted: #5e8ab4;
    --success: #34d399;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow: hidden;
    position: relative;
  }

  body::before {
    content: '';
    position: fixed;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(14,165,233,0.12) 0%, transparent 70%);
    top: 20%; left: 50%; transform: translateX(-50%);
    pointer-events: none;
    transition: opacity 0.5s;
  }

  .app {
    width: 100%;
    max-width: 390px;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 24px 32px;
    position: relative;
  }

  .header {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 52px 0 24px;
  }
  .header h1 {
    font-family: 'Syne', sans-serif;
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.5px;
    color: var(--text);
  }
  .settings-btn {
    width: 40px; height: 40px;
    border-radius: 12px;
    background: var(--surface);
    border: 1px solid rgba(56,189,248,0.15);
    color: var(--muted);
    font-size: 18px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
  }
  .settings-btn:active { transform: scale(0.92); background: rgba(56,189,248,0.1); }

  .stats-bar {
    display: flex;
    gap: 10px;
    width: 100%;
    margin-bottom: 28px;
  }
  .stat-chip {
    flex: 1;
    background: var(--surface);
    border: 1px solid rgba(56,189,248,0.12);
    border-radius: 14px;
    padding: 12px 10px;
    text-align: center;
  }
  .stat-chip .val {
    font-family: 'Syne', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: var(--water-light);
    line-height: 1;
  }
  .stat-chip .lbl {
    font-size: 10px;
    color: var(--muted);
    margin-top: 3px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .bottle-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    user-select: none;
    margin-bottom: 24px;
  }

  .bottle-wrap:active .bottle-body { transform: scale(0.97); }

  .bottle-svg {
    width: 200px;
    height: 340px;
    filter: drop-shadow(0 20px 40px rgba(14,165,233,0.25));
    transition: filter 0.3s;
  }

  .bottle-label {
    position: absolute;
    bottom: 70px;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    pointer-events: none;
  }
  .pct-text {
    font-family: 'Syne', sans-serif;
    font-size: 36px;
    font-weight: 800;
    color: #fff;
    text-shadow: 0 2px 12px rgba(0,0,0,0.4);
    line-height: 1;
  }
  .oz-text {
    font-size: 13px;
    color: rgba(255,255,255,0.7);
    margin-top: 2px;
  }

  .tap-hint {
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: opacity 0.3s;
  }
  .tap-hint span { font-size: 16px; }

  .drink-btn {
    width: 100%;
    height: 62px;
    border-radius: 18px;
    background: linear-gradient(135deg, var(--water-mid), var(--water-deep));
    border: none;
    color: white;
    font-family: 'Syne', sans-serif;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.3px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 8px 24px rgba(14,165,233,0.3);
    margin-bottom: 12px;
  }
  .drink-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.15), transparent);
  }
  .drink-btn:active { transform: scale(0.97); box-shadow: 0 4px 12px rgba(14,165,233,0.2); }

  .reset-btn {
    width: 100%;
    height: 48px;
    border-radius: 14px;
    background: transparent;
    border: 1px solid rgba(56,189,248,0.2);
    color: var(--muted);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }
  .reset-btn:active { background: rgba(56,189,248,0.06); color: var(--text); }

  .action-row {
    display: flex;
    gap: 10px;
    width: 100%;
    margin-bottom: 12px;
  }
  .action-row .drink-btn {
    flex: 1;
    margin-bottom: 0;
  }
  .dec-btn {
    width: 62px;
    height: 62px;
    border-radius: 18px;
    background: var(--surface);
    border: 1px solid rgba(56,189,248,0.2);
    color: var(--water-light);
    font-size: 28px;
    font-weight: 300;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    flex-shrink: 0;
  }
  .dec-btn:active { transform: scale(0.93); background: rgba(56,189,248,0.1); }
  .drink-btn { margin-bottom: 0; }

  /* ===== CREATINE CARD ===== */
  .creatine-card {
    width: 100%;
    border-radius: 18px;
    background: var(--surface);
    border: 1px solid rgba(56,189,248,0.15);
    padding: 16px 18px;
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 12px;
    transition: border-color 0.4s, background 0.4s;
    cursor: pointer;
    user-select: none;
    position: relative;
    overflow: hidden;
  }
  .creatine-card.unlocked { border-color: rgba(56,189,248,0.4); cursor: pointer; }
  .creatine-card.locked { opacity: 0.55; cursor: not-allowed; }
  .creatine-card.done { border-color: rgba(52,211,153,0.5); background: rgba(52,211,153,0.06); }
  .creatine-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(52,211,153,0.08), transparent);
    opacity: 0;
    transition: opacity 0.4s;
  }
  .creatine-card.done::before { opacity: 1; }

  .check-circle {
    width: 44px; height: 44px;
    border-radius: 50%;
    border: 2px solid rgba(56,189,248,0.3);
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
    transition: all 0.3s cubic-bezier(0.34,1.56,0.64,1);
    background: transparent;
  }
  .creatine-card.done .check-circle { background: var(--success); border-color: var(--success); transform: scale(1.1); }
  .creatine-card.unlocked:not(.done) .check-circle { border-color: rgba(56,189,248,0.6); }
  .creatine-info { flex: 1; }
  .creatine-title { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 2px; }
  .creatine-sub { font-size: 11px; color: var(--muted); transition: color 0.3s; }
  .creatine-card.done .creatine-sub { color: var(--success); }
  .creatine-card.unlocked:not(.done) .creatine-sub { color: var(--water-light); }
  .lock-icon { font-size: 16px; color: var(--muted); flex-shrink: 0; }

  /* Ripple */
  .ripple {
    position: absolute;
    border-radius: 50%;
    background: rgba(255,255,255,0.35);
    transform: scale(0);
    animation: rippleAnim 0.5s ease-out forwards;
    pointer-events: none;
  }
  @keyframes rippleAnim { to { transform: scale(4); opacity: 0; } }

  /* ===== SETTINGS PANEL ===== */
  .settings-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(4px);
    z-index: 100;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .settings-overlay.open { opacity: 1; pointer-events: all; }

  .settings-sheet {
    width: 100%;
    max-width: 390px;
    background: #0f1e35;
    border-radius: 28px 28px 0 0;
    padding: 28px 24px 48px;
    border: 1px solid rgba(56,189,248,0.15);
    border-bottom: none;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1);
  }
  .settings-overlay.open .settings-sheet { transform: translateY(0); }

  .sheet-handle {
    width: 40px; height: 4px;
    background: rgba(56,189,248,0.25);
    border-radius: 2px;
    margin: 0 auto 24px;
  }
  .settings-sheet h2 { font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 700; margin-bottom: 24px; }
  .field { margin-bottom: 20px; }
  .field label { display: block; font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
  .field-row { display: flex; align-items: center; background: var(--surface); border: 1px solid rgba(56,189,248,0.15); border-radius: 14px; overflow: hidden; }
  .field-row input { flex: 1; background: transparent; border: none; color: var(--text); font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 700; padding: 14px 16px; outline: none; -moz-appearance: textfield; }
  .field-row input::-webkit-inner-spin-button,
  .field-row input::-webkit-outer-spin-button { -webkit-appearance: none; }
  .field-row .unit { padding-right: 16px; color: var(--muted); font-size: 14px; }
  .field-row .step-btns { display: flex; flex-direction: column; border-left: 1px solid rgba(56,189,248,0.1); }
  .step-btn { width: 44px; height: 27px; background: transparent; border: none; color: var(--muted); font-size: 16px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.15s, color 0.15s; }
  .step-btn:first-child { border-bottom: 1px solid rgba(56,189,248,0.1); }
  .step-btn:active { background: rgba(56,189,248,0.15); color: var(--text); }

  .save-btn { width: 100%; height: 56px; border-radius: 16px; background: linear-gradient(135deg, var(--water-mid), var(--water-deep)); border: none; color: white; font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 700; cursor: pointer; margin-top: 8px; box-shadow: 0 8px 20px rgba(14,165,233,0.25); transition: transform 0.15s; }
  .save-btn:active { transform: scale(0.97); }

  .celebrate { position: fixed; inset: 0; pointer-events: none; z-index: 200; display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s; }
  .celebrate.show { opacity: 1; }
  .celebrate-msg { font-family: 'Syne', sans-serif; font-size: 32px; font-weight: 800; color: var(--success); text-align: center; text-shadow: 0 4px 24px rgba(52,211,153,0.5); animation: celebratePop 0.5s cubic-bezier(0.34,1.56,0.64,1) forwards; }
  @keyframes celebratePop { from { transform: scale(0.5); opacity: 0; } to { transform: scale(1); opacity: 1; } }

  .drop { position: fixed; font-size: 20px; pointer-events: none; z-index: 150; animation: floatDrop 1s ease-out forwards; }
  @keyframes floatDrop { 0% { transform: translateY(0) scale(1); opacity: 1; } 100% { transform: translateY(-120px) scale(0.5); opacity: 0; } }
</style>
</head>
<body>

<div class="app">
  <div class="header">
    <h1>Hydrate 💧</h1>
    <div class="settings-btn" onclick="openSettings()">⚙️</div>
  </div>

  <div class="stats-bar">
    <div class="stat-chip">
      <div class="val" id="statDrank">0</div>
      <div class="lbl">ml drank</div>
    </div>
    <div class="stat-chip">
      <div class="val" id="statLeft">2000</div>
      <div class="lbl">ml left</div>
    </div>
    <div class="stat-chip">
      <div class="val" id="statSips">0</div>
      <div class="lbl">servings</div>
    </div>
  </div>

  <div class="bottle-wrap" onclick="drinkWater(event)" id="bottleWrap">
    <svg class="bottle-svg" viewBox="0 0 200 340" id="bottleSvg" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <clipPath id="bottleClip">
          <path d="M 78 40 L 72 62 Q 40 80 36 120 L 30 280 Q 28 320 100 322 Q 172 320 170 280 L 164 120 Q 160 80 128 62 L 122 40 Z"/>
        </clipPath>
        <linearGradient id="waterGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#38bdf8" stop-opacity="0.95"/>
          <stop offset="100%" stop-color="#0284c7" stop-opacity="1"/>
        </linearGradient>
        <linearGradient id="shineGrad" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%" stop-color="white" stop-opacity="0.18"/>
          <stop offset="40%" stop-color="white" stop-opacity="0.05"/>
          <stop offset="100%" stop-color="white" stop-opacity="0"/>
        </linearGradient>
        <linearGradient id="glassGrad" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%" stop-color="#1e3a5f" stop-opacity="0.6"/>
          <stop offset="30%" stop-color="#0f2340" stop-opacity="0.3"/>
          <stop offset="70%" stop-color="#0f2340" stop-opacity="0.3"/>
          <stop offset="100%" stop-color="#1e3a5f" stop-opacity="0.6"/>
        </linearGradient>
      </defs>

      <rect x="78" y="14" width="44" height="30" rx="8" fill="#1e3a5f" stroke="rgba(56,189,248,0.3)" stroke-width="1.5"/>
      <rect x="82" y="18" width="36" height="22" rx="6" fill="#0f2340"/>
      <rect x="86" y="22" width="28" height="14" rx="4" fill="#162d4a" stroke="rgba(56,189,248,0.2)" stroke-width="1"/>
      <line x1="90" y1="22" x2="90" y2="36" stroke="rgba(56,189,248,0.15)" stroke-width="1"/>
      <line x1="96" y1="22" x2="96" y2="36" stroke="rgba(56,189,248,0.15)" stroke-width="1"/>
      <line x1="102" y1="22" x2="102" y2="36" stroke="rgba(56,189,248,0.15)" stroke-width="1"/>
      <line x1="108" y1="22" x2="108" y2="36" stroke="rgba(56,189,248,0.15)" stroke-width="1"/>

      <g clip-path="url(#bottleClip)">
        <rect id="waterRect" x="20" y="322" width="160" height="0" fill="url(#waterGrad)" opacity="0.92"/>
        <g id="waveGroup" opacity="0">
          <path id="wavePath" fill="rgba(56,189,248,0.6)">
            <animate attributeName="d" dur="2s" repeatCount="indefinite"
              values="M20,0 Q50,-8 80,0 Q110,8 140,0 Q165,-8 180,0 L180,20 L20,20 Z;M20,0 Q50,8 80,0 Q110,-8 140,0 Q165,8 180,0 L180,20 L20,20 Z;M20,0 Q50,-8 80,0 Q110,8 140,0 Q165,-8 180,0 L180,20 L20,20 Z"/>
          </path>
        </g>
        <g id="bubblesGroup" opacity="0">
          <circle cx="65" cy="0" r="3" fill="rgba(186,230,253,0.6)">
            <animate attributeName="cy" values="0;-40" dur="1.8s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0.6;0" dur="1.8s" repeatCount="indefinite"/>
          </circle>
          <circle cx="100" cy="0" r="2" fill="rgba(186,230,253,0.5)">
            <animate attributeName="cy" values="0;-55" dur="2.3s" repeatCount="indefinite" begin="0.5s"/>
            <animate attributeName="opacity" values="0.5;0" dur="2.3s" repeatCount="indefinite" begin="0.5s"/>
          </circle>
          <circle cx="135" cy="0" r="2.5" fill="rgba(186,230,253,0.55)">
            <animate attributeName="cy" values="0;-35" dur="1.5s" repeatCount="indefinite" begin="1s"/>
            <animate attributeName="opacity" values="0.55;0" dur="1.5s" repeatCount="indefinite" begin="1s"/>
          </circle>
        </g>
      </g>

      <path d="M 78 40 L 72 62 Q 40 80 36 120 L 30 280 Q 28 320 100 322 Q 172 320 170 280 L 164 120 Q 160 80 128 62 L 122 40 Z"
        fill="url(#glassGrad)" stroke="rgba(56,189,248,0.4)" stroke-width="2" stroke-linejoin="round"/>
      <path d="M 80 70 L 74 90 Q 55 105 52 140 L 48 240"
        stroke="url(#shineGrad)" stroke-width="10" fill="none" stroke-linecap="round"/>
      <g stroke="rgba(56,189,248,0.2)" stroke-width="1">
        <line x1="155" y1="150" x2="165" y2="150"/>
        <line x1="155" y1="190" x2="165" y2="190"/>
        <line x1="155" y1="230" x2="165" y2="230"/>
        <line x1="155" y1="270" x2="165" y2="270"/>
      </g>
    </svg>

    <div class="bottle-label">
      <div class="pct-text" id="pctText">0%</div>
      <div class="oz-text" id="ozText">0 ml / 2 L</div>
    </div>
  </div>

  <div class="tap-hint" id="tapHint">
    <span>👆</span> Tap the bottle to drink a serving
  </div>

  <div class="action-row">
    <button class="dec-btn" onclick="undoDrink(event)">−</button>
    <button class="drink-btn" onclick="drinkWater(event)">+ Add Serving</button>
  </div>

  <div class="creatine-card locked" id="creatineCard" onclick="toggleCreatine()">
    <div class="check-circle" id="checkCircle">💊</div>
    <div class="creatine-info">
      <div class="creatine-title">Creatine</div>
      <div class="creatine-sub" id="creatineSub">Unlocks at 2L — keep drinking!</div>
    </div>
    <div class="lock-icon" id="lockIcon">🔒</div>
  </div>

  <button class="reset-btn" onclick="resetDay()">Reset Day</button>
</div>

<!-- Settings Sheet -->
<div class="settings-overlay" id="settingsOverlay" onclick="handleOverlayClick(event)">
  <div class="settings-sheet">
    <div class="sheet-handle"></div>
    <h2>Settings</h2>
    <div class="field">
      <label>Daily Goal</label>
      <div class="field-row">
        <input type="number" id="inputGoal" value="2000" min="250" max="6000" step="250"/>
        <span class="unit">ml</span>
        <div class="step-btns">
          <button class="step-btn" onclick="step('goal',250)">▲</button>
          <button class="step-btn" onclick="step('goal',-250)">▼</button>
        </div>
      </div>
    </div>
    <div class="field">
      <label>Per Serving</label>
      <div class="field-row">
        <input type="number" id="inputServing" value="250" min="10" max="1000" step="50"/>
        <span class="unit">ml</span>
        <div class="step-btns">
          <button class="step-btn" onclick="step('serving',50)">▲</button>
          <button class="step-btn" onclick="step('serving',-50)">▼</button>
        </div>
      </div>
    </div>
    <button class="save-btn" onclick="saveSettings()">Save Settings</button>
  </div>
</div>

<div class="celebrate" id="celebrateEl">
  <div class="celebrate-msg">🎉 Goal Reached! 🎉</div>
</div>

<script>
  let goal = parseFloat(localStorage.getItem('wt_goal') || 2000);
  let serving = parseFloat(localStorage.getItem('wt_serving') || 250);
  let drank = parseFloat(localStorage.getItem('wt_drank') || 0);
  let lastReset = localStorage.getItem('wt_date') || '';
  let goalCelebrated = localStorage.getItem('wt_celebrated') === 'true';
  let creatineDone = localStorage.getItem('wt_creatine') === 'true';

  const today = new Date().toDateString();
  if (lastReset !== today) {
    drank = 0; goalCelebrated = false;
    localStorage.setItem('wt_date', today);
    localStorage.setItem('wt_drank', 0);
    localStorage.setItem('wt_celebrated', 'false');
    localStorage.setItem('wt_creatine', 'false');
  }

  function save() {
    localStorage.setItem('wt_drank', drank);
    localStorage.setItem('wt_celebrated', goalCelebrated);
    localStorage.setItem('wt_creatine', creatineDone);
  }

  function clamp(v, min, max) { return Math.max(min, Math.min(max, v)); }

  const BOTTLE_BOTTOM = 322;
  const BOTTLE_TOP = 62;
  const BOTTLE_HEIGHT = BOTTLE_BOTTOM - BOTTLE_TOP;

  function fmtVol(ml) {
    return ml >= 1000 ? (ml / 1000).toFixed(1) + ' L' : Math.round(ml) + ' ml';
  }

  function render(animated) {
    const pct = clamp(drank / goal, 0, 1);
    const waterHeight = pct * BOTTLE_HEIGHT;
    const waterY = BOTTLE_BOTTOM - waterHeight;

    const waterRect = document.getElementById('waterRect');
    const waveGroup = document.getElementById('waveGroup');
    const bubblesGroup = document.getElementById('bubblesGroup');

    waterRect.style.transition = animated ? 'y 0.9s cubic-bezier(0.22,1,0.36,1), height 0.9s cubic-bezier(0.22,1,0.36,1)' : 'none';
    waterRect.setAttribute('y', waterY);
    waterRect.setAttribute('height', waterHeight);

    if (pct > 0.01) {
      waveGroup.setAttribute('opacity', '1');
      bubblesGroup.setAttribute('opacity', '1');
      waveGroup.setAttribute('transform', `translate(0, ${waterY})`);
      bubblesGroup.setAttribute('transform', `translate(0, ${waterY})`);
    } else {
      waveGroup.setAttribute('opacity', '0');
      bubblesGroup.setAttribute('opacity', '0');
    }

    document.getElementById('pctText').textContent = Math.round(pct * 100) + '%';
    document.getElementById('ozText').textContent = `${fmtVol(drank)} / ${fmtVol(goal)}`;
    document.getElementById('statDrank').textContent = drank >= 1000 ? (drank/1000).toFixed(1)+'L' : Math.round(drank);
    document.getElementById('statLeft').textContent = Math.max(0, goal-drank) >= 1000 ? ((goal-drank)/1000).toFixed(1)+'L' : Math.max(0, Math.round(goal-drank));
    document.getElementById('statSips').textContent = Math.round(drank / serving);

    const card = document.getElementById('creatineCard');
    const sub = document.getElementById('creatineSub');
    const lockIcon = document.getElementById('lockIcon');
    const checkCircle = document.getElementById('checkCircle');
    const unlocked = drank >= 2000;
    if (creatineDone) {
      card.className = 'creatine-card done';
      sub.textContent = 'Taken ✓ Great work!';
      lockIcon.textContent = '';
      checkCircle.textContent = '✓';
    } else if (unlocked) {
      card.className = 'creatine-card unlocked';
      sub.textContent = 'Tap to mark as taken';
      lockIcon.textContent = '→';
      checkCircle.textContent = '💊';
    } else {
      card.className = 'creatine-card locked';
      const mlLeft = Math.max(0, 2000 - drank);
      sub.textContent = mlLeft >= 1000 ? `Unlocks at 2L — ${(mlLeft/1000).toFixed(1)}L to go` : `Unlocks at 2L — ${Math.round(mlLeft)}ml to go`;
      lockIcon.textContent = '🔒';
      checkCircle.textContent = '💊';
    }

    if (drank > 0) document.getElementById('tapHint').style.opacity = '0.4';
  }

  function drinkWater(e) {
    if (drank >= goal) { showCelebrate(); return; }
    drank = clamp(drank + serving, 0, goal);
    save(); render(true); spawnDroplets(e);
    if (drank >= goal && !goalCelebrated) {
      goalCelebrated = true; save();
      setTimeout(showCelebrate, 900);
    }
  }

  function toggleCreatine() {
    if (drank < 2000) return;
    creatineDone = !creatineDone;
    save(); render(false);
    if (creatineDone) {
      const card = document.getElementById('creatineCard');
      card.style.transform = 'scale(0.97)';
      setTimeout(() => card.style.transform = '', 200);
    }
  }

  function undoDrink(e) {
    if (drank <= 0) return;
    drank = Math.max(0, drank - serving);
    goalCelebrated = drank >= goal;
    save(); render(true); spawnDroplets(e);
  }

  function resetDay() {
    drank = 0; goalCelebrated = false; save(); render(true);
  }

  function spawnDroplets(e) {
    for (let i = 0; i < 4; i++) {
      const drop = document.createElement('div');
      drop.className = 'drop';
      drop.textContent = '💧';
      drop.style.left = ((e.clientX || 200) + (Math.random()-0.5)*60) + 'px';
      drop.style.top = (e.clientY || 300) + 'px';
      drop.style.animationDelay = (i * 0.08) + 's';
      document.body.appendChild(drop);
      setTimeout(() => drop.remove(), 1200);
    }
  }

  function showCelebrate() {
    const el = document.getElementById('celebrateEl');
    el.classList.add('show');
    setTimeout(() => el.classList.remove('show'), 2500);
  }

  function openSettings() {
    document.getElementById('inputGoal').value = goal;
    document.getElementById('inputServing').value = serving;
    document.getElementById('settingsOverlay').classList.add('open');
  }
  function closeSettings() { document.getElementById('settingsOverlay').classList.remove('open'); }
  function handleOverlayClick(e) { if (e.target === document.getElementById('settingsOverlay')) closeSettings(); }
  function step(field, delta) {
    if (field === 'goal') {
      const inp = document.getElementById('inputGoal');
      inp.value = clamp(parseFloat(inp.value) + delta, 250, 6000);
    } else {
      const inp = document.getElementById('inputServing');
      inp.value = clamp(parseFloat(inp.value) + delta, 10, 1000);
    }
  }
  function saveSettings() {
    goal = parseFloat(document.getElementById('inputGoal').value) || 2000;
    serving = parseFloat(document.getElementById('inputServing').value) || 250;
    localStorage.setItem('wt_goal', goal);
    localStorage.setItem('wt_serving', serving);
    if (drank > goal) { drank = goal; save(); }
    closeSettings(); render(true);
  }

  render(false);
</script>
</body>
</html>
